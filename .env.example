APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=changeme
RATE_LIMIT=60/minute
CORS_ORIGINS=http://localhost:3000

REDIS_URL=redis://redis:6379/0
QUEUE_NAME=jobs
MAX_WORKERS=1

TRANSCRIBE_PROVIDER=local
WHISPER_MODEL=small
LANGUAGE=pt

OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.5
LLM_MAX_CLIPS=5
MIN_CLIP_SEC=20
MAX_CLIP_SEC=90
TARGET_ASPECT=16:9
BURN_SUBTITLES=true

STORAGE_PROVIDER=local
DATA_DIR=/data
PUBLIC_BASE_URL=http://localhost:8000

S3_BUCKET=
S3_REGION=
S3_PREFIX=jobs/
S3_PRESIGN_TTL_SECONDS=86400

MAX_UPLOAD_MB=2048
ALLOWED_EXT=mp4,mov,mkv
URL_FETCH_ENABLED=false
WEBHOOK_ENABLED=false
JWT_ENABLED=false
RETENTION_DAYS=7

PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
FAST_CUT=false
